{
	"schemaVersion": 1,
	"id": "immersive-chests",
	"version": "${version}",
	"name": "Immersive Chests",
	"description": "A client-side camera immersion mod that repositions and orients the camera when interacting with chests, barrels, furnaces, crafting stations, and other container blocks.",
	"authors": [
		"Zack Bailey"
	],
	"contact": {
		"sources": "https://github.com/zacriah18/ImmersiveChests"
	},
	"license": "MIT",
	"icon": "assets/immersive-chests/icon.png",
	"environment": "client",
	"entrypoints": {
		"main": [
		"com.zackbailey.immersivechests.ImmersiveChests"
		],
		"client": [
		"com.zackbailey.immersivechests.client.ImmersivechestsClient"
		],
		"modmenu": [
			"com.zackbailey.immersivechests.client.ImmersiveChestsModMenu"
		]
	},
	"mixins": [
		{
			"config": "immersive-chests.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
	"fabricloader": ">=0.19.2",
	"minecraft": "~26.1.2",
	"java": ">=21",
	"fabric-api": ">=0.147.0",
	"cloth-config2": ">=26.1.154"
	},
	"suggests": {
	"modmenu": "*"
	}
}

